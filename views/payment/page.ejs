

<link rel="stylesheet" href="/css/payment.css">

<div class="lsp-page">

    <div class="lsp-payment-card">

        <!-- TOP -->
        <div class="lsp-payment-top">
            <div class="lsp-payment-badge">💳 Secure Payment</div>

            <h1 class="lsp-payment-title">Complete Your Payment</h1>

            <p class="lsp-payment-subtitle">
                Safe and encrypted payment gateway powered by Razorpay
            </p>
        </div>

        <!-- SERVICE -->
        <div class="lsp-service-box">
            <div class="lsp-service-icon">🛠</div>

            <div>
                <h2 class="lsp-service-name">
                    <%= booking.serviceName %>
                </h2>

                <p class="lsp-service-desc">
                    Professional verified service booking
                </p>
            </div>
        </div>

        <!-- DETAILS -->
        <div class="lsp-details-grid">

            <div class="lsp-detail-card">
                <span>Booking ID</span>
                <strong>#<%= booking._id ? booking._id.slice(0,6) : "NA" %></strong>
            </div>

            <div class="lsp-detail-card">
                <span>Payment Status</span>
                <strong><%= booking.paymentStatus %></strong>
            </div>

            <div class="lsp-detail-card">
                <span>Booking Status</span>
                <strong><%= booking.status %></strong>
            </div>

            <div class="lsp-detail-card">
                <span>Date</span>
                <strong>
                    <%= new Date(booking.date).toLocaleString('en-IN') %>
                </strong>
            </div>

        </div>

        <!-- PRICE -->
        <div class="lsp-price-box">

            <div>
                <p class="lsp-price-label">Total Amount</p>
                <h2 class="lsp-price">₹ <%= booking.price %></h2>
            </div>

            <button id="openModalBtn" class="lsp-pay-btn">
                Pay Now
            </button>

        </div>

    </div>
</div>

<!-- MODAL -->
<div id="paymentModal" class="lsp-modal">

    <div class="lsp-modal-content">

        <button id="closeModalBtn" class="lsp-close-btn">✕</button>

        <div class="lsp-modal-icon">💳</div>

        <h2 class="lsp-modal-title">Confirm Payment</h2>

        <p class="lsp-modal-subtitle">
            You are paying <strong>₹ <%= booking.price %></strong>
        </p>

        <button id="rzp-button" class="lsp-razorpay-btn">
            Pay with Razorpay
        </button>

    </div>

</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>

const modal = document.getElementById("paymentModal");

// OPEN
document.getElementById("openModalBtn").onclick = () => {
    modal.style.display = "flex";
};

// CLOSE
document.getElementById("closeModalBtn").onclick = () => {
    modal.style.display = "none";
};

// OUTSIDE CLOSE
window.addEventListener("click", (event) => {
    if (event.target === modal) {
        modal.style.display = "none";
    }
});

// PAYMENT
document.getElementById("rzp-button").addEventListener("click", async () => {

    try {

        const bookingId = "<%= booking._id %>";
        if (!bookingId || bookingId === "undefined") {
          console.log("❌ INVALID BOOKING ID");
          alert("Invalid booking ID");
          return;
        }

        if (!bookingId) {
            alert("Invalid booking ID");
            return;
        }

        const res = await fetch("/payment/create-order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                amount: <%= booking.price %>   // ❗ no *100 here
            })
        });

        const order = await res.json();

        const options = {
            key: "rzp_test_Snh7dRLGDl0qlR",
            amount: order.amount,
            currency: "INR",
            order_id: order.id,
            name: "HomeAssist",
            description: "Service Payment",

            handler: async function (response) {
                console.log("💳 PAYMENT RESPONSE:", response);
                console.log("📌 BOOKING ID:", bookingId);

                const paymentRes = await fetch(
                    `/payment/success/${bookingId}`,
                    {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            payment_id: response.razorpay_payment_id,
                            order_id: response.razorpay_order_id,
                            signature: response.razorpay_signature
                        })
                    }
                );

                const data = await paymentRes.json();

                if (data.success && data.redirect) {
                    window.location.href = data.redirect;
                } else {
                    alert("Payment succeeded but update failed");
                    console.error(data);
                }
            }
        };

        const rzp = new Razorpay(options);
        rzp.open();

    } catch (err) {
        console.log(err);
        alert("Payment failed");
    }
});

</script>